{
	"features": {
		"auth": {
			"files": {
				"remove": [
					"src/server/lib/auth.ts",
					"src/server/middleware/auth-guard.ts",
					"src/server/modules/auth/**",
					"src/server/db/tables/auth.ts",
					"src/server/schemas/database/auth.ts",
					"src/client/lib/auth.ts",
					"src/client/components/auth/**",
					"src/client/routes/login.tsx",
					"src/client/routes/profile.tsx"
				],
				"transform": [
					{
						"file": "src/server/routes/api.ts",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "../modules/auth/index"
								}
							},
							{
								"type": "function",
								"transformer": "removeArrayElement",
								"options": {
									"pattern": "authModule"
								}
							}
						]
					},
					{
						"file": "src/server/schemas/database/index.ts",
						"rules": [
							{
								"type": "function",
								"transformer": "removeBlock",
								"options": {
									"startPattern": "// Authentication schemas",
									"endPattern": "from \"./auth\";"
								}
							}
						]
					},
					{
						"file": "src/server/lib/types.ts",
						"condition": "hasDatabase && !hasAuth",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/lib-types-db-noauth.ts"
								}
							}
						]
					},
					{
						"file": "src/server/types/index.ts",
						"condition": "hasDatabase && !hasAuth",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/types-index-db-noauth.ts"
								}
							}
						]
					},
					{
						"file": "src/server/openapi/schemas.ts",
						"condition": "hasDatabase && !hasAuth",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/openapi-schemas-db-noauth.ts"
								}
							}
						]
					},
					{
						"file": "src/server/types/index.ts",
						"rules": [
							{
								"type": "function",
								"transformer": "removeType",
								"options": {
									"typeName": "AuthUser"
								}
							},
							{
								"type": "function",
								"transformer": "removeType",
								"options": {
									"typeName": "AuthSession"
								}
							},
							{
								"type": "function",
								"transformer": "removeType",
								"options": {
									"typeName": "SelectUser"
								}
							},
							{
								"type": "function",
								"transformer": "removeType",
								"options": {
									"typeName": "InsertUser"
								}
							},
							{
								"type": "function",
								"transformer": "removeType",
								"options": {
									"typeName": "User"
								}
							}
						]
					},
					{
						"file": "package.json",
						"rules": [
							{
								"type": "function",
								"transformer": "removeDependency",
								"options": {
									"dependencies": ["better-auth"]
								}
							}
						]
					},
					{
						"file": "src/index.tsx",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@/server/middleware/auth-guard"
								}
							},
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "app.use(\"/api/*\", authGuard);"
								}
							}
						]
					},
					{
						"file": "src/server/db/tables/index.ts",
						"rules": [
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "export * from \"./auth\";"
								}
							},
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "// Authentication tables"
								}
							}
						]
					},
					{
						"file": "src/server/middleware/index.ts",
						"rules": [
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "export { authGuard } from \"./auth-guard\";"
								}
							}
						]
					}
				]
			}
		},
		"database": {
			"files": {
				"remove": [
					"src/server/db/**",
					"src/server/middleware/database.ts",
					"src/server/schemas/database/**",
					"src/server/modules/posts/**",
					"drizzle.config.ts",
					"scripts/link-db.ts"
				],
				"transform": [
					{
						"file": "package.json",
						"rules": [
							{
								"type": "function",
								"transformer": "removeDependency",
								"options": {
									"dependencies": [
										"drizzle-orm",
										"drizzle-zod",
										"drizzle-kit",
										"better-sqlite3"
									]
								}
							},
							{
								"type": "function",
								"transformer": "removeScript",
								"options": {
									"scripts": [
										"db:generate",
										"db:push:local",
										"db:push:remote",
										"db:studio",
										"db:reset:local",
										"db:reset:remote",
										"gen:module"
									]
								}
							}
						]
					},
					{
						"file": "wrangler.toml",
						"rules": [
							{
								"type": "regex",
								"transformer": "removeBlock",
								"options": {
									"pattern": "\\[\\[d1_databases\\]\\][\\s\\S]*?(?=\\n\\[|$)"
								}
							}
						]
					},
					{
						"file": "src/server/lib/types.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/lib-types-minimal.ts"
								}
							}
						]
					},
					{
						"file": "src/client/routes/index.tsx",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/index-no-db.tsx"
								}
							}
						]
					},
					{
						"file": "src/server/routes/api.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "../modules/posts/index"
								}
							},
							{
								"type": "function",
								"transformer": "removeArrayElement",
								"options": {
									"pattern": "postsModule"
								}
							}
						]
					},
					{
						"file": "src/server/schemas/index.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/schemas-index-no-db.ts"
								}
							}
						]
					},
					{
						"file": "src/server/types/index.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/types-index-no-db.ts"
								}
							}
						]
					},
					{
						"file": "src/server/openapi/schemas.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/openapi-schemas-no-db.ts"
								}
							}
						]
					},
					{
						"file": "src/server/middleware/index.ts",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "export { database } from \"./database\";"
								}
							}
						]
					},
					{
						"file": "src/client/routes/__root.tsx",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@client/components/auth/user-menu"
								}
							},
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "<UserMenu />"
								}
							}
						]
					},
					{
						"file": "src/client/components/hello-demo.tsx",
						"condition": "!hasDatabase",
						"rules": [
							{
								"type": "replace",
								"transformer": "replaceFile",
								"options": {
									"template": "templates/replacements/hello-demo-no-db.tsx"
								}
							}
						]
					}
				]
			}
		}
	},
	"projectTypes": {
		"api-only": {
			"files": {
				"remove": ["src/utils/manifest.ts"],
				"transform": [
					{
						"file": "src/index.ts",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@/server/middleware/auth-guard"
								}
							},
							{
								"type": "function",
								"transformer": "removeStatement",
								"options": {
									"pattern": "app.use(\"/api/*\", authGuard);"
								}
							}
						]
					},
					{
						"file": "src/client/components/auth/login-form.tsx",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@client/lib/auth"
								}
							}
						]
					},
					{
						"file": "src/client/components/auth/user-menu.tsx",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@client/lib/auth"
								}
							}
						]
					},
					{
						"file": "src/client/components/auth/user-profile.tsx",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "@client/lib/auth"
								}
							}
						]
					}
				]
			}
		},
		"full-stack": {
			"files": {
				"transform": [
					{
						"file": "src/client/router.tsx",
						"condition": "!hasAuth",
						"rules": [
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "./routes/login"
								}
							},
							{
								"type": "function",
								"transformer": "removeImport",
								"options": {
									"module": "./routes/profile"
								}
							}
						]
					}
				]
			}
		}
	}
}
